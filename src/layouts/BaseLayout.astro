---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Designer × Builder — Hailey Ho', lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <nav class="site-nav">
      <div class="container">
        <a href="/designer-builder-blog/posts" class="nav-wordmark">
          <svg class="spike" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 1v16M1 9h16M3.05 3.05l11.9 11.9M14.95 3.05L3.05 14.95" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Designer × Builder
        </a>
        <ul class="nav-links">
          <li><a href="/designer-builder-blog/posts">文章</a></li>
          <li><a href="https://github.com/haileyho" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          <div class="footer-brand">
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 1v16M1 9h16M3.05 3.05l11.9 11.9M14.95 3.05L3.05 14.95" stroke="#cc785c" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Hailey Ho
          </div>
          <p class="footer-tagline">Product designer & builder. Writing about design, AI, and making things.</p>
        </div>
        <ul class="footer-links">
          <li><a href="/designer-builder-blog/posts">所有文章</a></li>
          <li><a href="https://github.com/haileyho/designer-builder-blog" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
      <div class="container">
        <p class="footer-copy">© {new Date().getFullYear()} Hailey Ho. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
