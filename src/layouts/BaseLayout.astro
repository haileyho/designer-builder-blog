---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Designer × Builder — Hailey Ho', lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P6HJJV26V7"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-P6HJJV26V7');
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="container">
        <a href="/designer-builder-blog/posts" class="nav-wordmark">
          <img src="/designer-builder-blog/logo.png" alt="Hailey Ho" class="nav-logo" />
        </a>
        <ul class="nav-links">
          <li><a href="/designer-builder-blog/posts">文章</a></li>
          <li><a href="https://github.com/haileyho" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          <div class="footer-brand">
            <img src="/designer-builder-blog/logo-white.png" alt="Hailey Ho" class="footer-logo" />
          </div>
          <p class="footer-tagline">Product designer & builder. Writing about design, AI, and making things.</p>
        </div>
        <ul class="footer-links">
          <li><a href="/designer-builder-blog/posts">所有文章</a></li>
          <li><a href="https://github.com/haileyho/designer-builder-blog" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
      <div class="container">
        <p class="footer-copy">© {new Date().getFullYear()} Hailey Ho. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
