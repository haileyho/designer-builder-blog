---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const featured = posts.find(p => p.slug === '20-ways-future-proof-design-career');
const { Content } = featured ? await featured.render() : { Content: null };
const post = featured;
---

<BaseLayout
  title={post ? post.data.title : 'Designer × Builder — Hailey Ho'}
  description={post?.data.description}
  lang="zh-TW"
>
  <div class="container">
    {post && (
      <>
        <header class="post-header">
          <div class="post-header-meta">
            <span class="post-card-tag lang-zh">中文</span>
            {post.data.tags?.map(tag => (
              <span class="post-card-tag">{tag}</span>
            ))}
          </div>
          <h1 class="post-header-title">{post.data.title}</h1>
          {post.data.description && (
            <p class="post-header-desc">{post.data.description}</p>
          )}
          <p style="font-size:0.875rem; color:var(--color-muted); margin-top:var(--space-xs);">
            {post.data.pubDate.toLocaleDateString('zh-TW', { year:'numeric', month:'long', day:'numeric' })}
            　·　Hailey Ho
          </p>
        </header>
        <hr class="post-divider" />
        <article class="prose post-body">
          <Content />
        </article>
      </>
    )}
  </div>
</BaseLayout>
