---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.slug !== 'hello-world')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Designer × Builder — Hailey Ho"
  description="Product designer & builder. Writing about design, AI, and making things."
  lang="zh-TW"
>
  <div class="home-hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Designer × Builder</p>
        <h1 class="hero-title">設計師，也是建造者</h1>
        <p class="hero-desc">
          Hailey Ho 的寫作空間。關於設計、AI，以及把想法做出來這件事。
        </p>
      </div>
    </div>
  </div>

  <div class="container">
    <section class="posts-section">
      <h2 class="posts-section-title">最新文章</h2>
      <div class="post-list">
        {posts.map(post => (
          <article class="post-card">
            <div class="post-card-meta">
              <span class="post-card-tag lang-zh">中文</span>
              {post.data.tags?.slice(0, 2).map(tag => (
                <span class="post-card-tag">{tag}</span>
              ))}
              <time class="post-card-date">
                {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
            <h2 class="post-card-title">
              <a href={`/designer-builder-blog/posts/${post.data.slug || post.slug}/`}>
                {post.data.title}
              </a>
            </h2>
            {post.data.description && (
              <p class="post-card-desc">{post.data.description}</p>
            )}
            <a class="post-card-link" href={`/designer-builder-blog/posts/${post.data.slug || post.slug}/`}>
              閱讀全文 →
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Hero */
  .home-hero {
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .hero-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 520px;
  }

  /* Posts section */
  .posts-section {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .posts-section-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .post-card {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .post-card-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-left: auto;
  }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    line-height: 1.3;
    margin-bottom: var(--space-sm);
  }

  .post-card-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-card-title a:hover {
    color: var(--color-accent);
  }

  .post-card-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
    max-width: 640px;
  }

  .post-card-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .post-card-link:hover {
    opacity: 0.75;
  }
</style>
